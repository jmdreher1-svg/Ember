{
  "name": "ember-standalone",
  "version": "2.0.0",
  "description": "EMBER — Fire Sprinkler Hydraulic Calculator (standalone) · DGA Consulting",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"node --watch server.js\"",
    "build": "vite build",
    "start": "node server.js",
    "serve": "npm run build && npm run start"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.3.4"
  }
}
